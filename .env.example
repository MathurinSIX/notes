# Copy to `.env.development` for local development (see `just init-env-dev`). Not committed.

# General
LOG_LEVEL=INFO
# Hostnames for Traefik (docker-compose.traefik.yml): http://${DOMAIN}, http://backend.${DOMAIN}, etc.
DOMAIN=notes.localhost

# Production frontend image: full URL the browser uses to call the API (baked in at `docker compose build`).
# If unset, the app falls back to //backend.<current-host>; set this for non-matching hostnames or HTTPS.
# VITE_API_URL=https://backend.example.com

# Production CORS: docker-compose.prod.yml defaults to http://${DOMAIN} and http://backend.${DOMAIN}.
# If you terminate TLS in front of Traefik, override both with https URLs, for example:
# FRONTEND_HOST=https://example.com
# BACKEND_CORS_ORIGINS=https://example.com,https://backend.example.com

# Traefik Docker provider: network services attach to for routing (see docker-compose.traefik.yml labels).
TRAEFIK_DOCKER_NETWORK=traefik-public

# Authentication
SECRET_KEY=secret_key

# First superuser (username + password). Created on backend prestart if missing.
# FIRST_SUPERUSER_EMAIL is still read as an alias for the username.
FIRST_SUPERUSER_USERNAME=admin
FIRST_SUPERUSER_PASSWORD=admin

# Postgres
POSTGRES_SERVER=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=notes
POSTGRES_SCHEMA=public
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# MinIO / S3 API URL for the *backend* process. If the API runs inside Docker, do not use
# localhost:9000 (that is the container itself). Use a hostname reachable on the Docker network:
# - Same Compose file as MinIO: http://storage:9000
# - MinIO from another stack on shared traefik-public (e.g. local_setup): http://minio:9000
#   (not http://minio.<domain>/ — *.localhost usually does not resolve correctly inside containers.)
# - MinIO on the host (Mac/Windows): http://host.docker.internal:9000
# From a backend running only on the host: http://localhost:9000 (or Traefik URL on the host).
BUCKET_URL=http://minio:9000
BUCKET_NAME=notes
# MinIO requires root password length >= 8; match S3_* to the MinIO root credentials.
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=adminadmin
S3_ACCESS_KEY_ID=admin
S3_SECRET_ACCESS_KEY=adminadmin

# OpenAI API Key
OPENAI_API_KEY=sk-proj-1234