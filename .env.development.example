# Copy to `.env.development` for local development (see `just init-env-dev`). Not committed.

# General
LOG_LEVEL=INFO
# Hostnames for Traefik (docker-compose.traefik.yml): http://${DOMAIN}, http://backend.${DOMAIN}, etc.
DOMAIN=notes.localhost

# Traefik Docker provider: network services attach to for routing (see docker-compose.traefik.yml labels).
TRAEFIK_DOCKER_NETWORK=traefik-public

# Authentication
SECRET_KEY=secret_key

# First superuser (username + password). Created on backend prestart if missing.
# FIRST_SUPERUSER_EMAIL is still read as an alias for the username.
FIRST_SUPERUSER_USERNAME=admin
FIRST_SUPERUSER_PASSWORD=admin

# From your machine use localhost:POSTGRES_PORT; containers override POSTGRES_PORT to 5432 for db.
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=notes
POSTGRES_SCHEMA=public
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# MinIO (S3 API). From containers use http://storage:9000; from the host use http://localhost:9000.
# MinIO rejects root passwords shorter than 8 characters — keep MINIO_ROOT_PASSWORD and
# S3_SECRET_ACCESS_KEY identical to what the storage container uses.
BUCKET_URL=http://storage:9000
BUCKET_NAME=notes
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Optional: pasted note images (POST /files/paste-image). Defaults match app.core.config.
# NOTE_PASTE_IMAGE_MAX_BYTES=26214400
# NOTE_IMAGE_GET_URL_EXPIRES_SECONDS=604800

# OpenAI API Key
OPENAI_API_KEY=sk-proj-1234
